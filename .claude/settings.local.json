{
  "permissions": {
    "ask": [
      "mcp__firebase__put_db",
      "mcp__firebase__patch_db",
      "mcp__firebase__delete_db",
      "mcp__firebase__post_db_push",
      "mcp__firebase__post_files_load",
      "mcp__firebase__post_backup_restore",
      "mcp__firebase__post_backup"
    ],
    "allow": [
      "Bash(bun run:*)",
      "mcp__firebase__get_db_keys",
      "mcp__firebase__get_db",
      "Bash(bun build:*)",
      "Bash(claude mcp add:*)",
      "Bash(echo:*)",
      "Bash(ls:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(head:*)",
      "Bash(bun test:*)",
      "Bash(bun:*)",
      "Bash(git add:*)",
      "Bash(npm show:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "firebase"
  ]
}
