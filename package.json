{
  "name": "@livx.cc/mcp-firebase",
  "version": "0.1.9",
  "description": "Standalone Firebase RTDB MCP server — query, update, and manage any Firebase RTDB instance via AI agents",
  "files": [
    "src/"
  ],
  "main": "./src/index.ts",
  "bin": {
    "mcp-firebase": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run src/cli.ts --stdio",
    "start": "bun run src/cli.ts --stdio",
    "publish-lib": "bun publish --access public",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:emulator": "firebase emulators:exec --only database 'bun test'",
    "emulator:start": "firebase emulators:start --only database"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "edge.libx.js": "^0.3.4",
    "firebase-admin": "^13.0.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.2",
    "firebase-tools": "^15.7.0",
    "typescript": "^5.7.3"
  }
}
